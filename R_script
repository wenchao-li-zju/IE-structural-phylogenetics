## ---- 8. Matched lexical baseline (IE-CoR) ----
#
# Cognate data for the same 16 languages were taken from IE-CoR
# (Anderson et al. 2025; https://iecor.clld.org), restricted to the
# 170 core-vocabulary meanings. For each meaning, each language's
# primary lexeme was coded by its cognate-set ID. The matrix `cogmat`
# thus has 16 rows (languages) and 170 columns (meanings), each cell a
# cognate-class integer.
#
# To reproduce: download IE-CoR v1.2 from https://iecor.clld.org,
# select the 16 study languages, and build cogmat from the cognate-set
# assignments (forms.csv joined to cognates.csv).
#
# cogmat <- read.csv("data/IE-CoR_16langs_cognates.csv", row.names = 1)

set.seed(1)
lexical_RF <- replicate(100, {
  idx <- sample(ncol(cogmat), 19)              # 19 concepts: matched budget
  sub <- cogmat[, idx, drop = FALSE]
  # cap each concept at 4 states, to match the structural discretization
  sub <- apply(sub, 2, function(col) {
    tb   <- sort(table(col), decreasing = TRUE)
    keep <- names(tb)[1:min(4, length(tb))]
    col[!(col %in% keep)] <- NA
    as.integer(factor(col))
  })
  d  <- dist.gene(sub, method = "pairwise")
  tr <- nj(d); tr$tip.label <- rownames(cogmat)
  RF.dist(tr, ref, normalize = TRUE)
})

cat("Lexical baseline RF: median", round(median(lexical_RF), 3),
    " range", paste(round(range(lexical_RF), 3), collapse = "-"), "\n")
# Expected: median 0.385, range 0.077-0.615